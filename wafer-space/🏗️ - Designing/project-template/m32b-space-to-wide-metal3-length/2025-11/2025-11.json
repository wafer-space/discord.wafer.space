    {
      "id": "1442132074147610655",
      "type": "Default",
      "timestamp": "2025-11-23T12:37:59.995+00:00",
      "timestampEdited": null,
      "callEndedTimestamp": null,
      "isPinned": false,
      "content": "I understand it as follows:\n\n`wide_m3` is all the m3 shapes that do not have at least one dimension that is in the range [0, 10), which seems to match what the written rule says",
      "author": {
        "id": "732347216412278825",
        "name": "urish",
        "discriminator": "0000",
        "nickname": "urish",
        "color": null,
        "isBot": false,
        "roles": [
          {
            "id": "1423020172595298314",
            "name": "Mod",
            "color": null,
            "position": 1
          }
        ],
        "avatarUrl": "2025-11_media/2b6c3aac0ae09fc8a72a4b2e17d7f9c9-39032.png"
      },
      "attachments": [],
      "embeds": [],
