    {
      "id": "1521899689899720725",
      "type": "Default",
      "timestamp": "2026-07-01T15:26:01.601+00:00",
      "timestampEdited": null,
      "callEndedTimestamp": null,
      "isPinned": false,
      "content": "@namibj :  I don't have any kind of temperature force unit, so I won't be able to determine if the power-up pattern is stable over temperature.  I would tend to expect it to be dependent on the 3.3V supply ramp, as well.",
      "author": {
        "id": "1365118310701600900",
        "name": "rtimothyedwards_19428",
        "discriminator": "0000",
        "nickname": "Tim Edwards",
        "color": null,
        "isBot": false,
        "roles": [],
        "avatarUrl": "2026-07_media/6bcc8e61db497b620550682309ace5d5-D89B4.png"
      },
      "attachments": [],
      "embeds": [],
      "stickers": [],
      "reactions": [],
      "mentions": [
        {
          "id": "262706220073222144",
