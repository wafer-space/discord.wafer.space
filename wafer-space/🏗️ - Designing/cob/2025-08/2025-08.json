      "timestamp": "2025-08-21T19:06:47.538+00:00",
      "timestampEdited": null,
      "callEndedTimestamp": null,
      "isPinned": false,
      "content": "Essentially, my goal for my next gf180 tapeout is it to ditch caravel and build a headless setup for my multi-project dies while also providing at least one analog output pin. In other words, I need a custom padring. And I heard there are people here already making progress towards such a thing.",
      "author": {
        "id": "220639106915368960",
        "name": "tholin",
        "discriminator": "0000",
        "nickname": "Tholin",
        "color": null,
        "isBot": false,
        "roles": [],
        "avatarUrl": "2025-08_media/edae5aadf146133e0448bfb1f0fa91c4-62B19.png"
      },
      "attachments": [],
      "embeds": [],
      "stickers": [],
      "reactions": [],
