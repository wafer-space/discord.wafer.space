    {
      "id": "1492425988284350637",
      "type": "Default",
      "timestamp": "2026-04-11T07:28:03.541+00:00",
      "timestampEdited": null,
      "callEndedTimestamp": null,
      "isPinned": false,
      "content": "I'm mostly concerned about them getting mixed up during the wire bonding - from past experience the factory:\n\nattaches the die to the PCBs\nPCBs with die go into trays like this\nnext the wire bonding\nbonded boards go back into trays\ntrays of bonded boards go for the glob top glue\nglue added then baked \n\nSee above photo from when we did the last TT08 COB",
      "author": {
        "id": "1184268085822238821",
        "name": "saladchap",
        "discriminator": "0000",
        "nickname": "stuart",
        "color": null,
        "isBot": false,
        "roles": [],
        "avatarUrl": "2026-04_media/4938353f83780f56050d92be930226f8-BA286.png"
      },
