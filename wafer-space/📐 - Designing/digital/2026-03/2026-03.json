    {
      "id": "1481880826475053097",
      "type": "Reply",
      "timestamp": "2026-03-13T05:05:21.046+00:00",
      "timestampEdited": null,
      "callEndedTimestamp": null,
      "isPinned": false,
      "content": "If it is helpful, I have a pretty nice systemverilog testbench I can share when I used to teach a SerDes course. It is integrated into virtuoso, Basically, it drops a random 8 bits out -> 8b10b encoding -> PISO -> channel driver -> channel -> CTLE/AMP/DFE -> slicer -> 10b8b decode ->  compares to the random 8bits that should have been sent and flags it. There is a CDR attached to the slicer. it is not PAM4 but it could be extended to that.",
      "author": {
        "id": "1034663307598123049",
        "name": "wspitts2",
        "discriminator": "0000",
        "nickname": "beardothaweirdo",
        "color": null,
        "isBot": false,
        "roles": [],
        "avatarUrl": "2026-03_media/f68931de5f8788cc1fd58cd59774f6da-0B4C2.png"
      },
