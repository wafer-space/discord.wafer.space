      "type": "Default",
      "timestamp": "2026-03-13T05:10:27.566+00:00",
      "timestampEdited": null,
      "callEndedTimestamp": null,
      "isPinned": false,
      "content": "The real power in it is that all bits that go down the channel are kept in a memory in the testbench and then they are checked as they come off the final reciever.  I also have some VerilogA and VerilogAMS of all the other components in there as well.",
      "author": {
        "id": "1034663307598123049",
        "name": "wspitts2",
        "discriminator": "0000",
        "nickname": "beardothaweirdo",
        "color": null,
        "isBot": false,
