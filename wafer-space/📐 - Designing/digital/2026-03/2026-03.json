    {
      "id": "1484271774932668518",
      "type": "Reply",
      "timestamp": "2026-03-19T19:26:07.58+00:00",
      "timestampEdited": null,
      "callEndedTimestamp": null,
      "isPinned": false,
      "content": "One thing with respect to the verilog-a -> OpenVAF flow is that the Verilog-a syntax support is very minimal. I believe this was intended to support device models that are in Verilog-a first and foremost, and less so about supporting behavior models e.g. for vcos or other analog blocks. So a lot of the models you might find on designer's guide won't work with this flow to my knowledge.",
      "author": {
        "id": "661042976646103116",
        "name": "tdextrous",
        "discriminator": "0000",
