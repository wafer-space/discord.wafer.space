          "discriminator": "0000",
          "nickname": "bailey",
          "color": null,
          "isBot": false,
          "roles": [],
          "avatarUrl": "2026-07_media/0-EB806.png"
        }
      ],
      "reference": {
        "messageId": "1524929309234561034",
