    {
      "id": "1525195541640904715",
      "type": "Reply",
      "timestamp": "2026-07-10T17:42:33.89+00:00",
      "timestampEdited": null,
      "callEndedTimestamp": null,
      "isPinned": false,
      "content": "This is a summary from my team, and because I’m seeing openroad yes it might be PNR\n\n> synthesis/signoff runs were spending huge time in OpenROAD.RepairDesignPostGPL. The dominant cause was a massive high-fanout reset net: i_chip_core.rst_n had about 38,354 terminals, and OpenROAD was serially building buffer trees for it. LibreLane parallelism knobs do not help this step much.",
      "author": {
        "id": "591049455499739147",
        "name": "crockpotveggies",
        "discriminator": "0000",
        "nickname": "J-Lo",
        "color": null,
        "isBot": false,
        "roles": [],
        "avatarUrl": "2026-07_media/a16190d2d5fede6615285958e112627c-CB61D.png"
      },
      "attachments": [],
