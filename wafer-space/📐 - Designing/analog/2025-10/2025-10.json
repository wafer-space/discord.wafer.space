    {
      "id": "1427201726154408007",
      "type": "Default",
      "timestamp": "2025-10-13T07:50:07.641+00:00",
      "timestampEdited": null,
      "callEndedTimestamp": null,
      "isPinned": false,
      "content": "great to know \uD83D\uDC4D  the applications I'm looking into are boutique synthesizers so the S-curve shaped distortion is often a feature rather than a bug \uD83D\uDE09",
      "author": {
        "id": "316742122751655939",
        "name": "mrmadbrain",
        "discriminator": "0000",
        "nickname": "madbrain",
        "color": null,
        "isBot": false,
