    {
      "id": "1521791559832567818",
      "type": "Default",
      "timestamp": "2026-07-01T08:16:21.384+00:00",
      "timestampEdited": null,
      "callEndedTimestamp": null,
      "isPinned": false,
      "content": "Also having CTS done separately on different blocks is dangerous as the clock tree depth may be different between blocks causing unexpected hold/setup violations for signals going between different blocks.\nIf I'm not mistaken, LibreLane supports P&R on subblocks separately but still CTS on top block.",
      "author": {
        "id": "728516105680846892",
        "name": "chips4makers",
        "discriminator": "0000",
        "nickname": "Chips4Makers aka Staf Verhaegen",
        "color": null,
        "isBot": false,
        "roles": [],
        "avatarUrl": "2026-07_media/2649a6faac7843086b3d82b1d8f657a3-81998.png"
      },
      "attachments": [],
