    {
      "id": "1521803184941830294",
      "type": "Default",
      "timestamp": "2026-07-01T09:02:33.026+00:00",
      "timestampEdited": null,
      "callEndedTimestamp": null,
      "isPinned": false,
      "content": "Thanks, appreciate the input. I'm not super familiar with this field and trying to learn. In my case, I'm studying SIMD lanes and thought to make the separate arithmetic units (say 32 of them) as I thought this is how 'real' designs are made. I had some severe congestion issues when trying to synth my top module",
      "author": {
        "id": "290925586266980352",
        "name": "osvel",
        "discriminator": "0000",
        "nickname": "Olle",
        "color": null,
        "isBot": false,
        "roles": [],
        "avatarUrl": "2026-07_media/0a78dc08258cf53bd8ec52dd3e14ef57-26F82.png"
