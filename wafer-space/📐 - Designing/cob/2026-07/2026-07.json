    {
      "id": "1527075445198295091",
      "type": "Default",
      "timestamp": "2026-07-15T22:12:37.825+00:00",
      "timestampEdited": null,
      "callEndedTimestamp": null,
      "isPinned": false,
      "content": "Cool, so probably nothing inherently wrong with keeping them, unless that's been a problem in the existing CoBs.",
