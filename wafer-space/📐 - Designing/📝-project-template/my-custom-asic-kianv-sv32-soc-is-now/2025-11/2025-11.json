    {
      "id": "1440769048173609193",
      "type": "Default",
      "timestamp": "2025-11-19T18:21:49.279+00:00",
      "timestampEdited": null,
      "callEndedTimestamp": null,
      "isPinned": false,
      "content": "Great questions — SDRAM is external because this process node doesn’t offer large embedded DRAM, only small SRAM blocks.To run Linux you need external memory.",
