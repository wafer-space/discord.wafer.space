    {
      "id": "1440777488920871042",
      "type": "Default",
      "timestamp": "2025-11-19T18:55:21.71+00:00",
      "timestampEdited": null,
      "callEndedTimestamp": null,
      "isPinned": false,
      "content": "I’ve done it with as little as 16MiB, booting to busybox with 12MiB free. So could maybe do 8MiB.",
      "author": {
        "id": "220639106915368960",
        "name": "tholin",
        "discriminator": "0000",
        "nickname": "Tholin",
        "color": null,
