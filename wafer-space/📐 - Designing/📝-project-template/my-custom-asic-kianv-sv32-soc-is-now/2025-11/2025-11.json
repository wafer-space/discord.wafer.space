    {
      "id": "1440783762278318130",
      "type": "Default",
      "timestamp": "2025-11-19T19:20:17.395+00:00",
      "timestampEdited": null,
      "callEndedTimestamp": null,
      "isPinned": false,
      "content": "1Mx16 Dynamic RAM with 5V power supply:\nhttps://www.issi.com/ww/pdf/41C16100.pdf\n4 of these and you get your 8MiB for busybox on mainline Linux at a much higher clockspeed",
      "author": {
        "id": "220639106915368960",
        "name": "tholin",
        "discriminator": "0000",
        "nickname": "Tholin",
        "color": null,
        "isBot": false,
