    {
      "id": "1482546387207065690",
      "type": "Default",
      "timestamp": "2026-03-15T01:10:03.09+00:00",
      "timestampEdited": null,
      "callEndedTimestamp": null,
      "isPinned": false,
      "content": "We also extended openocd to handle daisy chained JTAG taps. I have to look back at our notes from last year.",
      "author": {
        "id": "1034663307598123049",
        "name": "wspitts2",
        "discriminator": "0000",
        "nickname": "beardothaweirdo",
        "color": null,
        "isBot": false,
        "roles": [],
        "avatarUrl": "2026-03_media/f68931de5f8788cc1fd58cd59774f6da-0B4C2.png"
