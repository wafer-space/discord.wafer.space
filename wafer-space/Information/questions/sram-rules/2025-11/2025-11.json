    {
      "id": "1444043397395648593",
      "type": "Default",
      "timestamp": "2025-11-28T19:12:54.968+00:00",
      "timestampEdited": null,
      "callEndedTimestamp": null,
      "isPinned": false,
      "content": "Yes, I think that should be possible.\nAfaik it's not the cells that are detected, but rather the SRAM marker layer.\nHowever, as you probably know, there's no guarantee your cells will work after production, since the SRAM cells in the PDK were probably carefully designed to violate the normal core rules.",
      "author": {
        "id": "323371864074485771",
        "name": "mole99",
        "discriminator": "0000",
        "nickname": "Leo Moser (mole99)",
        "color": null,
