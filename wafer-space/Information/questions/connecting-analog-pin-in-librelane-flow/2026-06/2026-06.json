      "reactions": [],
      "mentions": [],
      "inlineEmojis": []
    },
    {
      "id": "1514921884645593150",
      "type": "Default",
      "timestamp": "2026-06-12T09:18:43.187+00:00",
      "timestampEdited": null,
      "callEndedTimestamp": null,
      "isPinned": false,
      "content": "Otherwise it goes \"whoa, this is useless!\" and optimizes it out, since all it sees is a cell with only an input and no output (I *believe*)",
      "author": {
        "id": "220639106915368960",
        "name": "tholin",
        "discriminator": "0000",
        "nickname": "Tholin",
