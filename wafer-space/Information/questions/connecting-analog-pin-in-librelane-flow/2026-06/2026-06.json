    {
      "id": "1514921765514514543",
      "type": "Default",
      "timestamp": "2026-06-12T09:18:14.784+00:00",
      "timestampEdited": null,
      "callEndedTimestamp": null,
      "isPinned": false,
      "content": "Its not even different electrically. The analog pad just provides a straight connection to the outside, the ports \"ASIG5V\" and \"PAD\" are electrically shorted, but LibreLane needs \"PAD\" to exist.",
      "author": {
        "id": "220639106915368960",
        "name": "tholin",
        "discriminator": "0000",
        "nickname": "Tholin",
        "color": null,
        "isBot": false,
        "roles": [],
