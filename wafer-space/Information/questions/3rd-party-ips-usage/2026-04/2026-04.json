    },
    {
      "id": "1498261299803586570",
      "type": "Default",
      "timestamp": "2026-04-27T09:55:30.222+00:00",
      "timestampEdited": null,
      "callEndedTimestamp": null,
      "isPinned": false,
      "content": "If you have a license for them and if they meet DRC, I don't see why it wouldn't be.",
      "author": {
        "id": "596068704471482370",
        "name": "246tnt",
        "discriminator": "0000",
        "nickname": "tnt",
        "color": null,
        "isBot": false,
        "roles": [],
