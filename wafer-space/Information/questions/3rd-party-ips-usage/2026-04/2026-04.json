      "callEndedTimestamp": null,
      "isPinned": false,
      "content": "Hello, may I ask whether it is permitted to use IP from third-party vendors (e.g., IO, SRAM, and standard cell IPs)? Can these be taped out in Wafer Space Run 2?",
      "author": {
        "id": "683216938255777809",
        "name": "daobaanhvn",
        "discriminator": "0000",
        "nickname": "daobaanhvn",
        "color": null,
        "isBot": false,
        "roles": [],
        "avatarUrl": "2026-04_media/4b7f5d556d30def875f2fbeddfbce6b2-57D15.png"
      },
      "attachments": [],
      "embeds": [],
      "stickers": [],
      "reactions": [],
