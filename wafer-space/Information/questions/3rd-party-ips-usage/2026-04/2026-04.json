    {
      "id": "1498367491163033803",
      "type": "Default",
      "timestamp": "2026-04-27T16:57:28.215+00:00",
      "timestampEdited": null,
      "callEndedTimestamp": null,
      "isPinned": false,
      "content": "Also, many third party proprietary vendors might not be happy that wafer.space won't sign an NDA or other similar contract with them.",
      "author": {
        "id": "169786952432746498",
        "name": "mithro_",
        "discriminator": "0000",
        "nickname": "Tim 'mithro' Ansell",
        "color": null,
        "isBot": false,
        "roles": [],
        "avatarUrl": "2026-04_media/9679bb77da48d47c905b398d98a83780-75B68.png"
      },
      "attachments": [],
