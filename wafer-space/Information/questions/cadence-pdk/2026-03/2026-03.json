      "id": "1486450491473920052",
      "type": "Default",
      "timestamp": "2026-03-25T19:43:34.082+00:00",
      "timestampEdited": null,
      "callEndedTimestamp": null,
      "isPinned": false,
      "content": "wafer.space doesn't care how you create the GDS but we don't supply access to any proprietary PDKs.\n\nYour GDS also needs to be 100% clean by the wafer.space platform, not whatever the cadence or any proprietary PDK says. \n\nWafer.space also does not support waivers from customers.",
      "author": {
        "id": "169786952432746498",
        "name": "mithro_",
        "discriminator": "0000",
        "nickname": "Tim 'mithro' Ansell",
        "color": null,
        "isBot": false,
        "roles": [],
        "avatarUrl": "2026-03_media/9679bb77da48d47c905b398d98a83780-75B68.png"
      },
      "attachments": [],
      "embeds": [],
      "stickers": [],
      "reactions": [],
