          "discriminator": "0000",
          "nickname": "Lofty",
          "color": null,
          "isBot": false,
          "roles": [],
          "avatarUrl": "2026-05_media/dd665ae27be32531af89aeb08fd05e04-1D5A4.png"
        }
      ],
      "reference": {
