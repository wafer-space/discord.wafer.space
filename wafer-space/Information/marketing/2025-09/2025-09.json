    {
      "id": "1413281839581237299",
      "type": "Default",
      "timestamp": "2025-09-04T21:57:28.063+00:00",
      "timestampEdited": null,
      "callEndedTimestamp": null,
      "isPinned": false,
      "content": "It has never been easier to design your own integrated circuit. What\u2019s missing is an affordable, straightforward path to real silicon that yields enough parts to build real products. For US$7,000, wafer.space delivers 1,000 raw dies so you can prototype, test, and ship.",
      "author": {
        "id": "169786952432746498",
        "name": "mithro_",
        "discriminator": "0000",
        "nickname": "Tim 'mithro' Ansell",
        "color": null,
        "isBot": false,
