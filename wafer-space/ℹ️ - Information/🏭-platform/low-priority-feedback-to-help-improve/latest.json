    },
    {
      "id": "1526880651888824340",
      "type": "Default",
      "timestamp": "2026-07-15T09:18:35.481+00:00",
      "timestampEdited": null,
      "callEndedTimestamp": null,
      "isPinned": false,
      "content": "Problem: \nI have multiple version of the same ASIC with different slot configurations, so I have multiple pre-check status's I need to keep an eye out for. Initially I would just pre-run pre-check on my end and only submit to the platform once pre-check is clean, but as my slot configuration issue has shown, sometime things slip through the cracks. \nIt would have been super usefull to have a place where I can get an overview of the pre-check status on the platform at a glace. \nFeatures missing: \n- Include pre-check status in notifications \nor/and\n- Include pre-check status indicator per project in the https://platform.wafer.space/projects/ overview",
      "author": {
        "id": "509798510170865675",
        "name": "essen__",
        "discriminator": "0000",
        "nickname": "Essen",
        "color": null,
        "isBot": false,
