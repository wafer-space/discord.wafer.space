* Xyce Testbench Harness for fl_mcpu32
* Target PDK: GlobalFoundries gf180mcuD

*** 1. INCLUDE PDK & DESIGN RULES ***
.include /home/namibj/projects/asic/pdk/gf180mcuD/libs.tech/xyce/design.xyce
.lib /home/namibj/projects/asic/pdk/gf180mcuD/libs.tech/xyce/sm141064.xyce typical
.lib /home/namibj/projects/asic/pdk/gf180mcuD/libs.tech/xyce/sm141064.xyce res_typical
.lib /home/namibj/projects/asic/pdk/gf180mcuD/libs.tech/xyce/sm141064.xyce diode_typical

*** 2. INCLUDE EXTRACTED SUBCIRCUIT ***
.include fl_mcpu32_flattened_only_m4_labels_pex__pdk_gf180mcuD__cthresh_0__subckt_top_on__hier_off.spice

*** 3. GLOBAL SIMULATION OPTIONS ***
*.OPTIONS NONLIN CONTINUATION=2
*.OPTIONS DEVICE temp=27.0

*** Try to make things faster? ***
*.OPTIONS LINSOL USE_IFPACK_FACTORY=1

*** 4. POWER SUPPLIES & GROUND REFERENCE ***
V_VSS VSS 0 DC 0V
V_VDD VDD 0 DC 3.3V  $ Assuming 5V operation for gf180mcuD standard IO/Core depending on your flavor $ actually it's 3.3V here!

*** 5. INPUT STIMULUS (TIED LOW FOR DC ANALYSIS) ***
V_clk            clk            0 DC 0V
V_clk_n          clk_n          0 DC 0V
V_rst_n          rst_n          0 DC 0V
V_rst_override_n rst_override_n 0 DC 0V

* 16-bit Data Input (din)
V_din0  din[0]  0 DC 0V
V_din1  din[1]  0 DC 0V
