      "inlineEmojis": []
    },
    {
      "id": "1444913954198655016",
      "type": "Default",
      "timestamp": "2025-12-01T04:52:11.884+00:00",
      "timestampEdited": null,
      "callEndedTimestamp": null,
      "isPinned": false,
      "content": "Yes I'd recommend a pull-down, otherwise pads can float up to mid rail and start drawing current. The pulls are pretty weak, like 100k or so.",
      "author": {
        "id": "803213471402688522",
        "name": "_luke_w_",
