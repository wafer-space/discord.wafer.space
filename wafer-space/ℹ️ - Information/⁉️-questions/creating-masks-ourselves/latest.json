      "timestampEdited": null,
      "callEndedTimestamp": null,
      "isPinned": false,
      "content": "looks like there's also a standardised mask set format spec\nhttps://store-us.semi.org/products/p04400-semi-p44-specification-for-open-artwork-system-interchange-standard-oasis-%C2%AE-specific-to-mask-tools",
      "author": {
