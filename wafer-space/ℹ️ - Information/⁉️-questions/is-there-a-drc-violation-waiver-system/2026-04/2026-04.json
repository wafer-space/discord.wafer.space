      "isPinned": false,
      "content": "That's what nmz said above, PM.4 ?  You need a 2um overlap of TopMetal for any passivation opening.",
      "author": {
        "id": "596068704471482370",
        "name": "246tnt",
        "discriminator": "0000",
        "nickname": "tnt",
        "color": null,
        "isBot": false,
        "roles": [],
