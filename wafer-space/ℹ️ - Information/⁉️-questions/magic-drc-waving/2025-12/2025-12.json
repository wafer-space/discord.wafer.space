    {
      "id": "1444995618555826177",
      "type": "Default",
      "timestamp": "2025-12-01T10:16:42.184+00:00",
      "timestampEdited": null,
      "callEndedTimestamp": null,
      "isPinned": false,
      "content": "The precheck also resulted in magic DRC errors on my end.\nThey are of type \"Can't overlap those layers\" and seem to relate to an overlap of COMP in two different cells.\nThe errors only occur inside the sram128x8, the other SRAMs are not affected.\nTaking a closer look at the cells which belong to these COMP layers, sram128x8 is the only one that uses the `xdec16_*` cell.\nThe other SRAMs use a combination of `xdec8_*` and `xdec32_*`, which are part of `MAGIC_GDS_FLATGLOB`. \nIt seems the flatglob for `xdec16_*` is missing. I added it to `MAGIC_GDS_FLATGLOB` and started another run \uD83E\uDD1E",
      "author": {
        "id": "323371864074485771",
        "name": "mole99",
        "discriminator": "0000",
        "nickname": "Leo Moser (mole99)",
        "color": null,
        "isBot": false,
        "roles": [
          {
            "id": "1423020172595298314",
            "name": "Mod",
            "color": null,
            "position": 4
          }
        ],
        "avatarUrl": "2025-12_media/3c7c17f3225f6e56f4dccd83f14383f2-73F83.png"
      },
