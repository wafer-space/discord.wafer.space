    {
      "id": "1506075524814868660",
      "type": "Default",
      "timestamp": "2026-05-18T23:26:26.646+00:00",
      "timestampEdited": null,
      "callEndedTimestamp": null,
      "isPinned": false,
      "content": "I think net name A is from the template, net name B for TinyQV looks like the function of the pin.  I'm not sure what it is for the other designs.",
      "author": {
        "id": "691780627338625077",
        "name": "rebelmike",
        "discriminator": "0000",
        "nickname": "RebelMike",
        "color": null,
        "isBot": false,
        "roles": [],
