    {
      "id": "1446248197444993024",
      "type": "Default",
      "timestamp": "2025-12-04T21:14:00.263+00:00",
      "timestampEdited": null,
      "callEndedTimestamp": null,
      "isPinned": false,
      "content": "The detail on the error is :\n```\nametal_eff: 202.5162\nratio: 401.817857143\nagate: 0.504\nmax_ratio: 400\npmetal_factor: 0.54\nadiodes: (0)\ndiode_factors: (800)\npmetal: 375.03\n```",
      "author": {
        "id": "596068704471482370",
        "name": "246tnt",
        "discriminator": "0000",
        "nickname": "tnt",
        "color": null,
        "isBot": false,
        "roles": [],
        "avatarUrl": "2025-12_media/88d17af9d19ab43565b0c46751ef7d12-DFEE5.png"
      },
      "attachments": [],
