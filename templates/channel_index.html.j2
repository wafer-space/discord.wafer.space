<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% if channel.is_thread %}🧵 {% else %}#{% endif %}{{ channel.display_name or channel.name }} Archive - {{ server.display_name }}</title>
    <link rel="stylesheet" href="/assets/style.css">
</head>
<body>
    <header>
        <nav class="breadcrumb">
            <a href="/index.html">Home</a> &gt;
            <a href="/{{ server.name }}/index.html">{{ server.display_name }}</a> &gt;
            {% if channel.category %}<span>{{ channel.category }}</span> &gt;{% endif %}
            <span>{% if channel.is_thread %}🧵 {% else %}#{% endif %}{{ channel.display_name or channel.name }}</span>
        </nav>
        <h1>{% if channel.is_thread %}🧵 {% else %}#{% endif %}{{ channel.display_name or channel.name }} Archive</h1>
    </header>

    <main>
        <section class="archives">
            <h2>Channel Messages</h2>
            {% for year, archives in archives_by_year.items() %}
            <h3>{{ year }}</h3>
            <ul class="archive-list">
                {% for archive in archives %}
                <li>
                    <strong>{{ archive.date }}</strong> ({{ archive.message_count }} messages)
                    <div class="formats">
                        <a href="/{{ server.name }}/{{ channel.name }}/{{ archive.date }}/{{ archive.date }}.html">HTML</a> |
                        <a href="/{{ server.name }}/{{ channel.name }}/{{ archive.date }}/{{ archive.date }}.txt">TXT</a> |
                        <a href="/{{ server.name }}/{{ channel.name }}/{{ archive.date }}/{{ archive.date }}.json">JSON</a> |
                        <a href="/{{ server.name }}/{{ channel.name }}/{{ archive.date }}/{{ archive.date }}.csv">CSV</a>
                    </div>
                </li>
                {% endfor %}
            </ul>
            {% endfor %}
        </section>

        {% if threads %}
        <section class="thread-list">
            <h2>Threads in this Channel ({{ threads|length }})</h2>
            {% for thread in threads %}
            <div class="thread-card">
                <h3>
                    <a href="/{{ server.name }}/{{ thread.path }}/index.html">
                        🧵 {{ thread.title }}
                    </a>
                </h3>
                <span class="meta">
                    {{ thread.total_messages }} message{{ '' if thread.total_messages == 1 else 's' }}
                    {% if thread.last_activity %} • Last activity: {{ thread.last_activity }}{% endif %}
                </span>
            </div>
            {% endfor %}
        </section>
        {% endif %}
    </main>

    <footer>
        <p><a href="/{{ server.name }}/index.html">← Back to {{ server.display_name }}</a></p>
    </footer>
</body>
</html>
